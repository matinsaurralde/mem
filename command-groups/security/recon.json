{
  "recon": {
    "description": "Quick domain recon -- no API keys, clean output",
    "commands": [
      {
        "cmd": "curl -s 'https://crt.sh/?q=%25.$DOMAIN&output=json' | jq -r '.[].name_value' | sort -u",
        "comment": "subdomains via certificate transparency"
      },
      {
        "cmd": "dig $DOMAIN A +short && dig $DOMAIN MX +short",
        "comment": "DNS A + MX records"
      },
      {
        "cmd": "curl -sI https://$DOMAIN | grep -iE 'server:|x-powered|strict-transport|content-security-policy'",
        "comment": "key HTTP headers"
      },
      {
        "cmd": "echo | openssl s_client -connect $DOMAIN:443 -servername $DOMAIN 2>/dev/null | openssl x509 -noout -dates -subject",
        "comment": "TLS cert expiry and subject"
      }
    ]
  }
}
